+    /// Helper: set env vars for the duration of a closure, then restore.
+    /// Not thread-safe — tests using this must not run in parallel with
+    /// other env-var-dependent tests.
+    fn with_env_vars<F, R>(vars: &[(&str, &str)], f: F) -> R
+    where
+        F: FnOnce() -> R,
+    {
+        // Save originals
+        let originals: Vec<(&str, Option<String>)> = vars
+            .iter()
+            .map(|(k, _)| (*k, std::env::var(k).ok()))
+            .collect();
+
+        // Set
+        for (k, v) in vars {
+            std::env::set_var(k, v);
+        }
+
+        let result = f();
+
+        // Restore
+        for (k, original) in &originals {
+            match original {
+                Some(v) => std::env::set_var(k, v),
+                None => std::env::remove_var(k),
+            }
+        }
+
+        result
+    }
+
+    /// Helper: clear env vars for the duration of a closure, then restore.
+    fn with_env_vars_removed<F, R>(vars: &[&str], f: F) -> R
+    where
+        F: FnOnce() -> R,
+    {
+        let originals: Vec<(&str, Option<String>)> =
+            vars.iter().map(|k| (*k, std::env::var(k).ok())).collect();
+
+        for k in vars {
+            std::env::remove_var(k);
+        }
+
+        let result = f();
+
+        for (k, original) in &originals {
+            match original {
+                Some(v) => std::env::set_var(k, v),
+                None => std::env::remove_var(k),
+            }
+        }
+
+        result
+    }
