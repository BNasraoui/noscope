+
+        let child = tmp.path().join("child.sh");
+        write_executable(
+            &child,
+            &format!(
+                "#!/bin/sh\nprintf ready > '{}'\ntrap '' TERM\ntrap '' INT\ntrap '' HUP\nwhile :; do sleep 1; done\n",
+                ready_file.display()
+            ),
+        );
+
+        let mint = tmp.path().join("mint.sh");
+        write_executable(
