+
+        let _ = scoped_env("XDG_CONFIG_HOME", tmp.path(), || cmd_run(args, false));
+        let injected = fs::read_to_string(&child_out).unwrap_or_default();
+        assert_eq!(
+            injected, "aws-env-secret",
