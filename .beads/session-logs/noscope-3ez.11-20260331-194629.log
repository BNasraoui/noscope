  {
    "_creationTime": 1774788567678.0437,
    "_id": "jn70zc9m0vfsxrwv8smne7kxt583vnwz",
    "createdBy": "kd795pd2q713d3q8q22z5d4a7s822ec0",
    "description": "PR_SET_PDEATHSIG set on child before exec ensures child receives SIGTERM if noscope dies for any reason (SIGKILL, crash, OOM). Process group kill on exit ensures grandchildren (forked by child) are also terminated. This is Linux-specific, defense-in-depth on top of TTL. Does not apply to mint mode.",
    "projectId": "9887a770-ff7d-44d4-aeeb-a9c7b2252b73",
    "sourceRefs": [],
    "statement": "noscope run mode shall manage the child as a process group, using PR_SET_PDEATHSIG to signal children when noscope dies, and killing the entire process group on exit to prevent orphaned grandchildren retaining credentials",
    "stats": {
      "childCount": 0.0,
      "openQuestionCount": 0.0,
      "resolutionCount": 0.0,
      "ruleCount": 1.0
    },
    "status": "discovery",
